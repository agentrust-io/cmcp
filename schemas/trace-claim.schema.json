{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cmcp.agentrust.io/schemas/trace-claim.schema.json",
  "title": "cMCP GatewayClaim",
  "description": "TRACE profile envelope emitted by the cMCP Gateway TEE at session close. The 'trace' sub-object contains canonical TRACE v0.1 fields; 'gateway' contains cmcp-specific addenda.",
  "type": "object",
  "additionalProperties": false,
  "required": ["cmcp_version", "trace", "gateway", "signature"],
  "properties": {
    "cmcp_version": {
      "type": "string",
      "enum": ["1.0"],
      "description": "Version of the cMCP claim envelope format."
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eat_profile", "iat", "subject", "runtime", "policy", "data_class", "cnf"],
      "description": "Canonical TRACE v0.1 fields for this gateway session.",
      "properties": {
        "eat_profile": {
          "type": "string",
          "const": "tag:agentrust.io,2026:trace-v0.1"
        },
        "iat": {
          "type": "integer",
          "minimum": 1700000000,
          "description": "Unix timestamp (seconds) when the claim was generated."
        },
        "subject": {
          "type": "string",
          "pattern": "^spiffe://",
          "description": "SPIFFE URI identifying the gateway session."
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["platform", "measurement"],
          "properties": {
            "platform": {
              "type": "string",
              "enum": [
                "intel-tdx", "amd-sev-snp", "nvidia-h100", "nvidia-blackwell",
                "aws-nitro", "arm-cca", "google-confidential-space", "tpm2"
              ]
            },
            "measurement": {
              "type": "string",
              "pattern": "^sha(256|384):[0-9a-f]+"
            },
            "rim_uri": { "type": "string" },
            "nonce": { "type": "string" },
            "firmware_version": { "type": "string" }
          }
        },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["bundle_hash", "enforcement_mode"],
          "properties": {
            "bundle_hash": {
              "type": "string",
              "pattern": "^sha(256|384):[0-9a-f]+"
            },
            "enforcement_mode": {
              "type": "string",
              "enum": ["enforce", "advisory", "silent"]
            },
            "version": { "type": "string" },
            "policy_uri": { "type": "string" }
          }
        },
        "data_class": {
          "type": "string",
          "description": "Highest sensitivity classification reached during the session."
        },
        "tool_transcript": {
          "type": "object",
          "additionalProperties": false,
          "required": ["hash"],
          "properties": {
            "hash": {
              "type": "string",
              "pattern": "^sha(256|384):[0-9a-f]+"
            },
            "call_count": { "type": "integer", "minimum": 0 },
            "transcript_uri": { "type": "string" },
            "entries": {
              "type": "array",
              "description": "Privacy-preserving per-call view (#126): tool name, data class, and policy decision, derived from the audit chain. No raw parameters or response bodies.",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["tool_name", "data_class", "decision"],
                "properties": {
                  "tool_name": { "type": "string" },
                  "data_class": { "type": "string" },
                  "decision": {
                    "type": "string",
                    "enum": ["allow", "deny", "redact", "advisory_deny", "fault", "n/a"]
                  }
                }
              }
            }
          }
        },
        "cnf": {
          "type": "object",
          "additionalProperties": false,
          "required": ["jwk"],
          "properties": {
            "jwk": {
              "type": "object",
              "required": ["kty"],
              "properties": {
                "kty": { "type": "string" },
                "crv": { "type": "string" },
                "x": { "type": "string" },
                "y": { "type": "string" },
                "kid": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "gateway": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id", "audit_chain", "call_summary", "catalog",
        "attestation_generated_at", "attestation_validity_seconds",
        "attestation_stale", "catalog_exceptions"
      ],
      "description": "cmcp-specific addenda outside the canonical TRACE spec.",
      "properties": {
        "session_id": { "type": "string" },
        "audit_chain": {
          "type": "object",
          "additionalProperties": false,
          "required": ["root", "tip", "length"],
          "properties": {
            "root": { "type": "string" },
            "tip": { "type": "string" },
            "length": { "type": "integer", "minimum": 0 }
          }
        },
        "call_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tool_calls_total", "tool_calls_allowed", "tool_calls_denied",
            "tool_calls_faulted", "tools_invoked", "session_max_sensitivity",
            "call_graph_summary"
          ],
          "properties": {
            "tool_calls_total": { "type": "integer", "minimum": 0 },
            "tool_calls_allowed": { "type": "integer", "minimum": 0 },
            "tool_calls_denied": { "type": "integer", "minimum": 0 },
            "tool_calls_faulted": { "type": "integer", "minimum": 0 },
            "tools_invoked": { "type": "array", "items": { "type": "string" } },
            "session_max_sensitivity": { "type": "string" },
            "call_graph_summary": {
              "type": "object",
              "additionalProperties": false,
              "required": ["compliance_domains_touched", "cross_boundary_events"],
              "properties": {
                "compliance_domains_touched": {
                  "type": "array", "items": { "type": "string" }
                },
                "cross_boundary_events": {
                  "type": "array", "items": { "type": "object" }
                }
              }
            }
          }
        },
        "catalog": {
          "type": "object",
          "additionalProperties": false,
          "required": ["hash", "drift_detected"],
          "properties": {
            "hash": {
              "type": "string",
              "pattern": "^sha(256|384):[0-9a-f]+"
            },
            "drift_detected": { "type": "boolean" }
          }
        },
        "agent_identity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "manifest_id",
            "agent_id",
            "authenticated_subject",
            "subject_source",
            "issuer",
            "issuer_key_id",
            "policy_bundle_hash",
            "tool_catalog_hash"
          ],
          "description": "Optional Agent Manifest binding carried by issue #302. The runtime emits this only after the signed manifest, authenticated agent subject, policy hash, and catalog hash have been checked at session creation.",
          "properties": {
            "manifest_id": { "type": "string" },
            "agent_id": {
              "type": "string",
              "pattern": "^spiffe://"
            },
            "authenticated_subject": {
              "type": "string",
              "pattern": "^spiffe://"
            },
            "subject_source": {
              "type": "string",
              "enum": ["config", "svid", "manifest-dev"],
              "description": "Source of the authenticated_subject assertion. config means configured runtime input, svid means transport/mTLS SVID, and manifest-dev means dev-mode fallback from manifest.agent_id."
            },
            "issuer": {
              "type": "string",
              "pattern": "^spiffe://"
            },
            "issuer_key_id": { "type": "string" },
            "policy_bundle_hash": {
              "type": "string",
              "pattern": "^sha(256|384):[0-9a-f]+"
            },
            "tool_catalog_hash": {
              "type": "string",
              "pattern": "^sha(256|384):[0-9a-f]+"
            }
          }
        },
        "attestation_generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "attestation_validity_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "attestation_stale": { "type": "boolean" },
        "catalog_exceptions": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "signature": {
      "type": "string",
      "description": "Base64url-encoded Ed25519 signature over the canonical JSON body (all fields except this one)."
    }
  }
}
